# ─── ORBIT-GUARD Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Brave Search API ────────────────────────────────────────────────────────
# Used for: live space news, similar repo discovery, conjunction event context
# Get your key at: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# ─── CelesTrak / Space-Track ─────────────────────────────────────────────────
# Optional: Space-Track.org credentials for higher-fidelity conjunction data
# Register at: https://www.space-track.org/auth/createAccount
SPACETRACK_USER=
SPACETRACK_PASS=

# ─── App Settings ────────────────────────────────────────────────────────────
# How often to refresh SOCRATES data (seconds). Default: 6 hours
SOCRATES_CACHE_TTL=21600

# Streamlit server port
PORT=8501
